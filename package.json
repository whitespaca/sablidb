{
  "name": "sablidb",
  "version": "1.2.0",
  "description": "Segmented Adaptive Bloom-LSM Inverted Index for JSON documents.",
  "type": "module",
  "private": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "examples:check": "tsc -p tsconfig.examples.json --noEmit",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint && npm run build && npm run examples:check && npm run test"
  },
  "keywords": [
    "json",
    "database",
    "embedded-database",
    "nosql",
    "search",
    "index",
    "bloom-filter",
    "lsm"
  ],
  "author": "whitespaca",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/whitespaca/sabli.git"
  },
  "homepage": "https://github.com/whitespaca/sabli#readme",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "typesea": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
